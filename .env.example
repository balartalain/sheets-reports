# Copiar este archivo a ".env" y completar los valores.
# ".env" NO se versiona (ver .gitignore); este archivo de ejemplo sí.

# --- Django core ---

# Clave secreta de Django. En producción es OBLIGATORIO generar una propia
# y mantenerla en secreto (no usar el valor por defecto de settings.py).
# Generar una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta-unica-en-produccion

# En producción SIEMPRE debe ser False.
DEBUG=True

# En producción es obligatorio listar los dominios/IPs que sirven la app,
# separados por comas. Ejemplo: reportes.uapa.edu.do,www.reportes.uapa.edu.do
ALLOWED_HOSTS=localhost,127.0.0.1

# Prefijo de ruta bajo el que corre la app en producción, sin slash final
# (ej. si Apache define Alias /sheets-reports -> esta app, usar /sheets-reports).
# Vacío en desarrollo, donde la app corre en la raíz "/".
REPORT_PATH=

# --- Base de datos ---

# Si no se define, la app usa SQLite local (db.sqlite3), pensado solo para
# desarrollo. En producción definir una base de datos real, por ejemplo Postgres:
#   DATABASE_URL=postgres://USUARIO:PASSWORD@HOST:5432/NOMBRE_DB
DATABASE_URL=

# --- Google Sheets ---

# Ruta al archivo JSON de credenciales de la service account de Google.
# La hoja de cálculo debe estar compartida con el email de la service account.
GOOGLE_SHEETS_CREDENTIALS_PATH=/ruta/a/tu/credentials.json

# --- Gemini ---

# API key de Gemini, usada para generar código Python de widgets a partir de un prompt.
GEMINI_API_KEY=tu-api-key-de-gemini
