# Ruta al archivo JSON de credenciales de la service account de Google
# La hoja de cálculo debe estar compartida con el email de la service account
GOOGLE_SHEETS_CREDENTIALS_PATH=/ruta/a/tu/credentials.json

# API key de Gemini, usada para generar código Python de widgets a partir de un prompt
GEMINI_API_KEY=tu-api-key-de-gemini
